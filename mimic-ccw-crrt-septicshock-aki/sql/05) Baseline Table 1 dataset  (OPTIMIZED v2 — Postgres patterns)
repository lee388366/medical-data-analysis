-- ============================================================
-- 05) Baseline Table 1 dataset  (OPTIMIZED v2 — Postgres patterns)
-- Output: data_extract_crrt.cohort_baseline_v1
--
-- Optimizations applied (postgres-patterns skill):
--   • CTE cohort extended with baseline_start (t0-6h) — single expression, better planning
--   • Composite indexes: equality first, then range (stay_id/hadm_id + time)
--   • Indexes added for ventilation & vasoactive_agent (overlap queries)
--   • APSIII: LATERAL + LIMIT 1 to avoid duplicate rows if multiple per stay
--   • HTN: ICD conditions simplified with regex (ICD-9 ^40[1-5], ICD-10 ^I1[0-3]|^I15)
--   • Nephrotoxic: single case-insensitive regex instead of 12× ILIKE
--   • PF ratio: NULLIF(b.fio2, 0) to avoid repeated fio2 > 0 check
--
-- Original NEW fields: first_careunit, admission_year, gcs_baseline, apsiii_score,
--   dm, htn, chf, ckd, liver_disease, malignancy, copd,
--   crystalloid_ml_kg, colloid_flag, nephrotoxic_flag.
-- ============================================================

CREATE SCHEMA IF NOT EXISTS data_extract_crrt;

-- ── Indexes on source tables (equality first, then range — Postgres cheat sheet) ─
CREATE INDEX IF NOT EXISTS idx_mimic_derived_vitalsign_stay_chart
  ON mimiciv_derived.vitalsign (stay_id, charttime DESC);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_chemistry_hadm_chart
  ON mimiciv_derived.chemistry (hadm_id, charttime DESC);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_bg_hadm_chart
  ON mimiciv_derived.bg (hadm_id, charttime DESC);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_enzyme_hadm_chart
  ON mimiciv_derived.enzyme (hadm_id, charttime DESC);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_coagulation_hadm_chart
  ON mimiciv_derived.coagulation (hadm_id, charttime DESC);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_cbc_hadm_chart
  ON mimiciv_derived.complete_blood_count (hadm_id, charttime DESC);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_weight_stay
  ON mimiciv_derived.weight_durations (stay_id, starttime DESC);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_sofa_stay_end
  ON mimiciv_derived.sofa (stay_id, endtime DESC);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_ne_stay_end
  ON mimiciv_derived.norepinephrine_equivalent_dose (stay_id, endtime DESC);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_gcs_stay_chart
  ON mimiciv_derived.gcs (stay_id, charttime DESC);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_apsiii_stay
  ON mimiciv_derived.apsiii (stay_id);
CREATE INDEX IF NOT EXISTS idx_mimic_icu_inputevents_stay_start
  ON mimiciv_icu.inputevents (stay_id, starttime);
CREATE INDEX IF NOT EXISTS idx_mimic_hosp_prescriptions_hadm_start
  ON mimiciv_hosp.prescriptions (hadm_id, starttime);
CREATE INDEX IF NOT EXISTS idx_mimic_hosp_diagnoses_hadm
  ON mimiciv_hosp.diagnoses_icd (hadm_id);

-- Overlap queries (starttime < t0 AND endtime > baseline_start)
CREATE INDEX IF NOT EXISTS idx_mimic_derived_ventilation_stay_start
  ON mimiciv_derived.ventilation (stay_id, starttime);
CREATE INDEX IF NOT EXISTS idx_mimic_derived_vasoactive_stay_start
  ON mimiciv_derived.vasoactive_agent (stay_id, starttime);

-- ── Main query ────────────────────────────────────────────────────────────────
DROP TABLE IF EXISTS data_extract_crrt.cohort_baseline_v1 CASCADE;
CREATE TABLE data_extract_crrt.cohort_baseline_v1 AS

WITH
cohort AS (
  SELECT
    stay_id, subject_id, hadm_id,
    intime, outtime,
    age, gender, race, insurance,
    los_icu, kdigo3_time, t0_time,
    t0_time - INTERVAL '6 hour' AS baseline_start
  FROM data_extract_crrt."301_ss_aki3_t0_no_rrt_cohort"
)

SELECT
  c.subject_id,
  c.hadm_id,
  c.stay_id,
  c.intime,
  c.outtime,
  c.t0_time,

  icu_det.first_careunit,
  EXTRACT(YEAR FROM c.intime)::INT AS admission_year,

  c.age,
  c.gender,
  c.race,
  c.insurance,
  w.weight_kg,

  cc.charlson_comorbidity_index AS cci,
  sf.sofa_baseline,
  gcs.gcs_baseline,
  ap.apsiii_score,

  v.hr,
  v.sbp,
  v.dbp,
  v.map,
  v.rr,
  v.spo2,
  v.temp_c,

  cb.wbc,
  cb.hb,
  cb.plt,
  ch.na,
  ch.cl,
  ch.k,
  ch.hco3,
  ch.scr,
  ch.bun,
  enz.ast,
  enz.alt,
  b.ph,
  b.lactate,
  b.pao2,
  b.fio2,
  CASE
    WHEN b.pao2 IS NOT NULL AND b.fio2 IS NOT NULL AND b.fio2 > 0
    THEN b.pao2 / NULLIF(b.fio2, 0)
    ELSE NULL
  END AS pf_ratio,
  cg.inr,

  GREATEST(COALESCE(cc.diabetes_without_cc, 0),
           COALESCE(cc.diabetes_with_cc, 0))                AS dm,
  COALESCE(htn.htn, 0)                                      AS htn,
  COALESCE(cc.congestive_heart_failure, 0)                  AS chf,
  COALESCE(cc.renal_disease, 0)                              AS ckd,
  GREATEST(COALESCE(cc.mild_liver_disease, 0),
           COALESCE(cc.severe_liver_disease, 0))              AS liver_disease,
  GREATEST(COALESCE(cc.malignant_cancer, 0),
           COALESCE(cc.metastatic_solid_tumor, 0))            AS malignancy,
  COALESCE(cc.chronic_pulmonary_disease, 0)                   AS copd,

  sp.mv_baseline,
  sp.vaso_baseline,
  sp.ne_eq_baseline,

  CASE
    WHEN w.weight_kg > 0 THEN cr.crystalloid_ml / w.weight_kg
    ELSE NULL
  END AS crystalloid_ml_kg,
  co.colloid_flag,
  nt.nephrotoxic_flag

FROM cohort c

LEFT JOIN mimiciv_icu.icustays icu_det
  ON icu_det.stay_id = c.stay_id

LEFT JOIN LATERAL (
  SELECT wd.weight AS weight_kg
  FROM mimiciv_derived.weight_durations wd
  WHERE wd.stay_id = c.stay_id
    AND wd.starttime <= c.t0_time
    AND COALESCE(wd.endtime, c.t0_time) >= c.t0_time
    AND wd.weight IS NOT NULL
  ORDER BY wd.starttime DESC
  LIMIT 1
) w ON true

LEFT JOIN mimiciv_derived.charlson cc
  ON cc.hadm_id = c.hadm_id

LEFT JOIN LATERAL (
  SELECT
    v.heart_rate  AS hr,
    v.sbp,
    v.dbp,
    v.mbp         AS map,
    v.resp_rate   AS rr,
    v.spo2,
    v.temperature AS temp_c
  FROM mimiciv_derived.vitalsign v
  WHERE v.stay_id = c.stay_id
    AND v.charttime >  c.baseline_start
    AND v.charttime <= c.t0_time
  ORDER BY v.charttime DESC
  LIMIT 1
) v ON true

LEFT JOIN LATERAL (
  SELECT
    ch.sodium      AS na,
    ch.chloride    AS cl,
    ch.potassium   AS k,
    ch.bicarbonate AS hco3,
    ch.creatinine  AS scr,
    ch.bun
  FROM mimiciv_derived.chemistry ch
  WHERE ch.hadm_id = c.hadm_id
    AND ch.charttime >  c.baseline_start
    AND ch.charttime <= c.t0_time
  ORDER BY ch.charttime DESC
  LIMIT 1
) ch ON true

LEFT JOIN LATERAL (
  SELECT b.ph, b.lactate, b.po2 AS pao2, b.fio2
  FROM mimiciv_derived.bg b
  WHERE b.hadm_id = c.hadm_id
    AND b.charttime >  c.baseline_start
    AND b.charttime <= c.t0_time
  ORDER BY b.charttime DESC
  LIMIT 1
) b ON true

LEFT JOIN LATERAL (
  SELECT e.ast, e.alt
  FROM mimiciv_derived.enzyme e
  WHERE e.hadm_id = c.hadm_id
    AND e.charttime >  c.baseline_start
    AND e.charttime <= c.t0_time
  ORDER BY e.charttime DESC
  LIMIT 1
) enz ON true

LEFT JOIN LATERAL (
  SELECT cg.inr
  FROM mimiciv_derived.coagulation cg
  WHERE cg.hadm_id = c.hadm_id
    AND cg.charttime >  c.baseline_start
    AND cg.charttime <= c.t0_time
  ORDER BY cg.charttime DESC
  LIMIT 1
) cg ON true

LEFT JOIN LATERAL (
  SELECT
    cb.wbc,
    cb.hemoglobin AS hb,
    cb.platelet   AS plt
  FROM mimiciv_derived.complete_blood_count cb
  WHERE cb.hadm_id = c.hadm_id
    AND cb.charttime >  c.baseline_start
    AND cb.charttime <= c.t0_time
  ORDER BY cb.charttime DESC
  LIMIT 1
) cb ON true

LEFT JOIN LATERAL (
  SELECT (g.gcs_motor + g.gcs_verbal + g.gcs_eyes) AS gcs_baseline
  FROM mimiciv_derived.gcs g
  WHERE g.stay_id = c.stay_id
    AND g.charttime >  c.baseline_start
    AND g.charttime <= c.t0_time
    AND g.gcs_motor  IS NOT NULL
    AND g.gcs_verbal IS NOT NULL
    AND g.gcs_eyes   IS NOT NULL
  ORDER BY g.charttime DESC
  LIMIT 1
) gcs ON true

-- APSIII: LATERAL + LIMIT 1 (one row per stay in MIMIC; safe if schema varies)
LEFT JOIN LATERAL (
  SELECT a.apsiii AS apsiii_score
  FROM mimiciv_derived.apsiii a
  WHERE a.stay_id = c.stay_id
  LIMIT 1
) ap ON true

LEFT JOIN LATERAL (
  SELECT
    EXISTS (
      SELECT 1 FROM mimiciv_derived.ventilation vv
      WHERE vv.stay_id = c.stay_id
        AND vv.starttime < c.t0_time
        AND COALESCE(vv.endtime, c.t0_time) > c.baseline_start
        AND vv.ventilation_status = 'InvasiveVent'
    )::int AS mv_baseline,
    EXISTS (
      SELECT 1 FROM mimiciv_derived.vasoactive_agent va
      WHERE va.stay_id = c.stay_id
        AND va.starttime < c.t0_time
        AND COALESCE(va.endtime, c.t0_time) > c.baseline_start
        AND (  COALESCE(va.norepinephrine, 0) > 0
            OR COALESCE(va.epinephrine,    0) > 0
            OR COALESCE(va.phenylephrine,  0) > 0
            OR COALESCE(va.vasopressin,    0) > 0
            OR COALESCE(va.dopamine,       0) > 0)
    )::int AS vaso_baseline,
    (SELECT ne.norepinephrine_equivalent_dose
     FROM mimiciv_derived.norepinephrine_equivalent_dose ne
     WHERE ne.stay_id = c.stay_id
       AND ne.starttime < c.t0_time
       AND COALESCE(ne.endtime, c.t0_time) > c.baseline_start
       AND ne.norepinephrine_equivalent_dose IS NOT NULL
     ORDER BY ne.endtime DESC
     LIMIT 1) AS ne_eq_baseline
  FROM (SELECT 1) _
) sp ON true

LEFT JOIN LATERAL (
  SELECT s.sofa_24hours AS sofa_baseline
  FROM mimiciv_derived.sofa s
  WHERE s.stay_id = c.stay_id
    AND s.endtime >  c.baseline_start
    AND s.endtime <= c.t0_time
    AND s.sofa_24hours IS NOT NULL
  ORDER BY s.endtime DESC
  LIMIT 1
) sf ON true

-- HTN: ICD-9 401–405, ICD-10 I10–I13, I15 — simplified with regex
LEFT JOIN LATERAL (
  SELECT EXISTS (
    SELECT 1 FROM mimiciv_hosp.diagnoses_icd d
    WHERE d.hadm_id = c.hadm_id
      AND (
        (d.icd_version = 9  AND d.icd_code ~ '^40[1-5]')
        OR
        (d.icd_version = 10 AND (d.icd_code ~ '^I1[0-3]' OR d.icd_code ~ '^I15'))
      )
  )::int AS htn
  FROM (SELECT 1) _
) htn ON true

LEFT JOIN LATERAL (
  SELECT COALESCE(SUM(ie.amount), 0) AS crystalloid_ml
  FROM mimiciv_icu.inputevents ie
  WHERE ie.stay_id = c.stay_id
    AND ie.starttime >= c.intime
    AND ie.starttime <  c.t0_time
    AND ie.itemid IN (
        225158, 225159, 225161, 225828, 225944,
        226364, 226375, 227533, 220949, 220950,
        225797, 225825, 225827, 225941
    )
    AND ie.amountuom = 'mL'
) cr ON true

LEFT JOIN LATERAL (
  SELECT EXISTS (
    SELECT 1 FROM mimiciv_icu.inputevents ie
    WHERE ie.stay_id = c.stay_id
      AND ie.starttime >= c.intime
      AND ie.starttime <  c.t0_time
      AND ie.itemid IN (225174, 225795, 225796)
  )::int AS colloid_flag
  FROM (SELECT 1) _
) co ON true

-- Nephrotoxic: single case-insensitive regex (gentamicin|tobramycin|…|polymyxin)
LEFT JOIN LATERAL (
  SELECT EXISTS (
    SELECT 1 FROM mimiciv_hosp.prescriptions p
    WHERE p.hadm_id = c.hadm_id
      AND p.starttime >= c.intime
      AND p.starttime <  c.t0_time
      AND p.drug ~* 'gentamicin|tobramycin|amikacin|streptomycin|vancomycin|ketorolac|ibuprofen|indomethacin|naproxen|amphotericin|colistin|polymyxin'
  )::int AS nephrotoxic_flag
  FROM (SELECT 1) _
) nt ON true
;

-- ── Indexes on result table (composite: equality first) ───────────────────────
CREATE INDEX IF NOT EXISTS idx_baseline_v1_stay
  ON data_extract_crrt.cohort_baseline_v1 (stay_id);
CREATE INDEX IF NOT EXISTS idx_baseline_v1_hadm
  ON data_extract_crrt.cohort_baseline_v1 (hadm_id);
CREATE INDEX IF NOT EXISTS idx_baseline_v1_subject
  ON data_extract_crrt.cohort_baseline_v1 (subject_id);

ANALYZE data_extract_crrt.cohort_baseline_v1;

